# Copie para .env.local (dev) — em produção (EasyPanel), configure cada uma
# dessas nas variáveis de ambiente do serviço.
#
# NEXT_PUBLIC_SUPABASE_URL e NEXT_PUBLIC_SUPABASE_ANON_KEY também precisam
# ser passadas como BUILD ARGS do Dockerfile (ver README), não só como env
# vars de runtime — o Next.js as inlina no bundle do client durante o build.

# Supabase — Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Token que o n8n deve enviar em `Authorization: Bearer <token>` ao chamar
# /api/campaigns/[id]/status e /api/campaigns/[id]/report. Gere uma string
# aleatória longa (ex: openssl rand -hex 32) e configure o mesmo valor
# como header fixo no HTTP Request node do n8n.
N8N_SERVICE_TOKEN=

# Token que protege o endpoint manual de sweep de webhooks
# (POST /api/internal/process-webhooks, header `x-internal-token`) — o
# retry automático já roda sozinho via cron interno; esse endpoint é só um
# gatilho manual opcional. Gere outra string aleatória.
INTERNAL_API_TOKEN=
